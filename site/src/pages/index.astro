---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<StarlightPage
  frontmatter={{
    title: "webgpu-spritebatch",
    template: "splash",
    hero: { title: " ", tagline: " " },
    pagefind: false,
  }}
  headings={[]}
>
  <div class="home-page not-content">
    <div class="hero-section">
      <canvas id="hero-boids" class="hero-boids" aria-hidden="true"></canvas>
      <!-- <div class="hero-badge">Inspired by XNA / MonoGame</div> -->
      <h1 class="hero-title">
        <span class="accent">SpriteBatch</span> for WebGPU
      </h1>
      <p class="hero-subtitle">
        Draw thousands of textured, tinted, rotated 2D sprites with a familiar
        <code>begin</code>&nbsp;/&nbsp;<code>draw</code>&nbsp;/&nbsp;<code
          >end</code
        >
        workflow &mdash; entirely on the GPU.
      </p>
      <div class="hero-actions">
        <a href={`${baseUrl}getting-started/installation/`} class="btn-primary"
          >Install Now</a
        >
        <a href={`${baseUrl}demos/`} class="btn-secondary">Live Demos</a>
        <a
          href="https://github.com/DanFessler/webgpu-spritebatch"
          class="btn-secondary btn-github"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path
              fill="currentColor"
              d="M12 .5a12 12 0 0 0-3.79 23.39c.6.11.82-.26.82-.58v-2.04c-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.73.08-.73 1.21.09 1.85 1.25 1.85 1.25 1.07 1.84 2.82 1.31 3.5 1 .11-.78.42-1.31.76-1.61-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.12-.3-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.29-1.55 3.3-1.23 3.3-1.23.66 1.66.24 2.88.12 3.18.77.84 1.24 1.91 1.24 3.22 0 4.61-2.81 5.63-5.49 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.22.7.83.58A12 12 0 0 0 12 .5Z"
            ></path>
          </svg>
          GitHub Repo
        </a>
      </div>

      <div class="install-callout" aria-label="Install command">
        <!-- <span>npm install webgpu-spritebatch</span> -->
        <span>Install</span>
        <code>npm install webgpu-spritebatch</code>
      </div>
    </div>

    <script>
      import { startHeroBoids } from "../hero-boids.ts";

      const hero = document.querySelector<HTMLElement>(".hero-section");
      const canvas = document.querySelector<HTMLCanvasElement>("#hero-boids");
      if (hero && canvas) startHeroBoids(hero, canvas);
    </script>

    <section class="code-showcase">
      <div class="section-eyebrow">Small API surface</div>
      <h2>Draw sprites without building a renderer first</h2>
      <p>
        Create a render surface, begin a batch, issue draw calls, and submit the
        frame. The library handles the WebGPU batching details underneath.
      </p>
      <div class="hero-code">
        <pre><code><span style="color:#7c8da4">const</span> surface = <span style="color:#7c8da4">await</span> RenderSurface.create(canvas)
<span style="color:#7c8da4">const</span> batch   = <span style="color:#7c8da4">new</span> SpriteBatch(surface)
<span style="color:#7c8da4">const</span> tex     = <span style="color:#7c8da4">await</span> Texture2D.fromUrl(surface, <span style="color:#a5d6ff">'/hero.png'</span>)

surface.beginFrame({'{'} clearColor: Color.cornflowerBlue {'}'})
batch.begin()
batch.draw(tex, {'{'}
  position: [<span style="color:var(--hero-code-number)">100</span>, <span style="color:var(--hero-code-number)">80</span>],
  scale: <span style="color:var(--hero-code-number)">2</span>,
  rotation: <span style="color:var(--hero-code-number)">0.1</span>,
{'}'})
batch.end()
surface.endFrame()</code></pre>
      </div>
      <a href={`${baseUrl}getting-started/first-sprite/`} class="code-docs-link"
        >Walk through your first sprite &rarr;</a
      >
    </section>

    <section class="motivation">
      <h2>Why webgpu-spritebatch?</h2>
      <p>
        If you've used <span class="highlight">XNA, MonoGame, or FNA</span>, you
        know SpriteBatch: a clean, low-ceremony API that batches textured quads
        into efficient GPU draw calls. On the web, you can go all-in with a full
        engine (PixiJS, Phaser, Babylon) or wrestle raw WebGPU yourself. Neither
        is ideal when all you want is
        <span class="highlight">fast, correct 2D sprite rendering</span> without an
        opinion about your game loop, scene graph, or asset pipeline.
      </p>
      <p>
        This library fills that gap. It gives you <span class="highlight"
          >instanced rendering</span
        >, sort modes, blend presets, custom WGSL shaders, render textures,
        cameras, and spritesheet animation &mdash; all in a small,
        TypeScript-first package that stays out of your way.
      </p>
    </section>

    <section class="features">
      <div class="feature-card">
        <svg class="feature-icon" viewBox="0 0 24 24" aria-hidden="true">
          <path d="m13 2-9 12h7l-1 8 9-12h-7l1-8Z"></path>
        </svg>
        <h3>Instanced Rendering</h3>
        <p>
          One draw call per texture group. Thousands of sprites at 60 fps with
          minimal GPU overhead.
        </p>
      </div>
      <div class="feature-card">
        <svg class="feature-icon" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M4 5h16v14H4V5Zm4 4h8M8 13h5"></path>
        </svg>
        <h3>Custom WGSL Shaders</h3>
        <p>
          Plug in any fragment shader while keeping the built-in vertex and
          instance layout. Add CRT, grayscale, outlines, or anything you can
          write in WGSL.
        </p>
      </div>
      <div class="feature-card">
        <svg class="feature-icon" viewBox="0 0 24 24" aria-hidden="true">
          <path
            d="M5 7h14v12H5V7Zm3-3h8l2 3H6l2-3Zm2 9a2 2 0 1 0 4 0 2 2 0 0 0-4 0Z"
          ></path>
        </svg>
        <h3>Render Textures</h3>
        <p>
          Draw sprites into offscreen textures for post-processing, minimaps, or
          pixel-art virtual resolutions.
        </p>
      </div>
      <div class="feature-card">
        <svg class="feature-icon" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 3v18M3 12h18M6 6l12 12M18 6 6 18"></path>
        </svg>
        <h3>Camera2D</h3>
        <p>
          Pan, zoom, and rotate with a familiar XNA-style transform matrix.
          World/screen coordinate conversion included.
        </p>
      </div>
      <div class="feature-card">
        <svg class="feature-icon" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M4 7h10M4 17h10M17 5v4M17 15v4M14 7h6M14 17h6"></path>
        </svg>
        <h3>Sort & Blend Modes</h3>
        <p>
          Deferred, texture, front-to-back, or back-to-front sorting. Alpha,
          additive, opaque, and premultiplied blending.
        </p>
      </div>
      <div class="feature-card">
        <svg class="feature-icon" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M7 3h7l4 4v14H7V3Zm7 0v5h4M9 13h6M9 17h4"></path>
        </svg>
        <h3>TypeScript-First</h3>
        <p>
          Full type declarations, strong autocomplete, and clear option objects.
          No runtime type coercion surprises.
        </p>
      </div>
      <div class="feature-card">
        <svg class="feature-icon" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M4 6h16v12H4V6Zm4 0v12M16 6v12M4 10h16M4 14h16"></path>
        </svg>
        <h3>Sprite Animation</h3>
        <p>
          Frame sequencing for spritesheets with loop, once, and ping-pong
          modes. Slice and pick sub-animations from a master sheet.
        </p>
      </div>
      <div class="feature-card">
        <svg class="feature-icon" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M5 4h14v16H5V4Zm3 3h8v8H8V7Zm9 11h.01M7 18h.01"></path>
        </svg>
        <h3>DPI-Aware</h3>
        <p>
          All coordinates use CSS pixels. The canvas renders at native device
          resolution automatically for crisp Retina output.
        </p>
      </div>
    </section>

    <section class="comparison">
      <h2>When to use it</h2>
      <p class="comparison-lede">
        Pick the layer that matches how much rendering infrastructure you want
        to own.
      </p>
      <div class="comparison-table-wrap">
        <table class="comparison-table">
          <thead>
            <tr>
              <th>Approach</th>
              <th>Best for</th>
              <th>Trade-off</th>
            </tr>
          </thead>
          <tbody>
            <tr class="recommended">
              <th scope="row">
                <strong>webgpu-spritebatch</strong>
                <span>Best fit for focused sprite rendering</span>
              </th>
              <td>
                Fast 2D sprite rendering with full control over your game loop,
                architecture, and asset flow.
              </td>
              <td>No scene graph, physics, or asset pipeline included.</td>
            </tr>
            <tr>
              <th scope="row">
                <strong>Full engine</strong>
                <span>Pixi, Phaser, Babylon, etc.</span>
              </th>
              <td>
                Complete game framework with scenes, plugins, and higher-level
                opinions.
              </td>
              <td>Larger dependency and may not use WebGPU natively.</td>
            </tr>
            <tr>
              <th scope="row">
                <strong>Raw WebGPU</strong>
                <span>Maximum rendering ownership</span>
              </th>
              <td
                >Total ownership of every pipeline, buffer, shader, and render
                pass.</td
              >
              <td>Significant boilerplate before drawing basic sprites.</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="cta-footer">
      <h2>Ready to draw some sprites?</h2>
      <p>Get up and running in under a minute.</p>
      <div class="hero-actions">
        <a href={`${baseUrl}getting-started/installation/`} class="btn-primary"
          >Install Now</a
        >
        <a href={`${baseUrl}demos/`} class="btn-secondary">Try the Demos</a>
      </div>
    </section>
  </div>
</StarlightPage>
